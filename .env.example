# ============================================
# OPTION 1: Ollama (LOCAL, 100% FREE)
# ============================================
# Install: https://ollama.com
# Then run: ollama pull qwen2.5
# No env vars needed — auto-detects localhost:11434

# ============================================
# OPTION 2: Cloud API (DashScope / OpenRouter)
# ============================================
# DashScope: https://dashscope.aliyun.com/
# QWEN_API_KEY=your-api-key-here

# Optional: override Qwen model (default: qwen-plus for cloud, qwen2.5 for Ollama)
# QWEN_MODEL=qwen-max

# Optional: custom endpoint (e.g. OpenRouter)
# QWEN_BASE_URL=https://openrouter.ai/api/v1

# Optional: Port for local development
# PORT=3000

# App URL for absolute links
# NEXT_PUBLIC_APP_URL=https://runek.vercel.app
